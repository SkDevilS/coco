# Flask Settings
SECRET_KEY=CHANGE_THIS_TO_SECURE_RANDOM_STRING_IN_PRODUCTION
FLASK_DEBUG=False
FLASK_ENV=production

# JWT Settings
JWT_SECRET_KEY=CHANGE_THIS_TO_SECURE_RANDOM_JWT_KEY_IN_PRODUCTION
JWT_ACCESS_TOKEN_EXPIRES=24
JWT_REFRESH_TOKEN_EXPIRES=720

# Database Settings
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=barringer_pharma_db
DB_USER=barringer_user
DB_PASSWORD=CHANGE_THIS_TO_SECURE_DB_PASSWORD
DB_CHARSET=utf8mb4

# Database Pool Settings
DB_POOL_SIZE=10
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30
DB_MAX_OVERFLOW=20
SQLALCHEMY_TRACK_MODIFICATIONS=False
SQLALCHEMY_ECHO=False

# File Upload Settings
UPLOAD_FOLDER=/var/www/barringer/barringer/backend/uploads
MAX_CONTENT_LENGTH=16777216
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,webp

# Domain Configuration
MAIN_DOMAIN=barringerpharma.shop
MAIN_URL=https://barringerpharma.shop
ADMIN_DOMAIN=admin.barringerpharma.shop
ADMIN_URL=https://admin.barringerpharma.shop
API_DOMAIN=api.barringerpharma.shop
API_URL=https://api.barringerpharma.shop

# Upload URL Configuration
UPLOAD_BASE_URL=https://api.barringerpharma.shop/uploads

# CORS Settings
CORS_ORIGINS=https://barringerpharma.shop,https://admin.barringerpharma.shop,https://www.barringerpharma.shop,http://localhost:5173,http://localhost:5174
CORS_SUPPORTS_CREDENTIALS=True
CORS_MAX_AGE=3600

# Application Settings
ITEMS_PER_PAGE=20
SESSION_TIMEOUT=60

# Logging Settings
LOG_LEVEL=INFO
LOG_FILE=/var/www/barringer/barringer/backend/logs/barringer.log
LOG_SQL_QUERIES=False
